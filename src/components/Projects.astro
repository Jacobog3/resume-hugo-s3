---
import type { SiteContent } from '../i18n/en';

interface Props {
  projects: SiteContent['projects'];
}

const { projects } = Astro.props;
---

<section id="projects" class="section" style="background: var(--bg-secondary);">
  <div class="section-inner">
    <p class="section-kicker">Delivery</p>
    <h2 class="section-title">{projects.title}</h2>

    <div
      style="
        margin-top: 2.5rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      "
    >
      {projects.items.map((project) => (
        <div class="card" style="padding: 1.75rem; display: flex; flex-direction: column;">
          <div style="flex: 1;">
            <h3
              style="
                font-family: var(--font-sans);
                font-size: 1rem;
                font-weight: 700;
                color: var(--text);
                margin: 0 0 0.75rem 0;
              "
            >
              {project.title}
            </h3>
            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1rem;">
              {project.badges.map((badge) => (
                <span class="badge">{badge}</span>
              ))}
            </div>
            <p style="color: var(--text-secondary); font-size: 0.875rem; line-height: 1.65; margin: 0 0 1.5rem 0;">
              {project.content}
            </p>
          </div>
          <a
            href={project.ctaUrl}
            target={project.ctaUrl.startsWith('mailto') ? '_self' : '_blank'}
            rel={project.ctaUrl.startsWith('mailto') ? '' : 'noopener'}
            class="btn-outline"
            style="align-self: flex-start;"
          >
            {project.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
