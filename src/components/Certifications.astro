---
import type { SiteContent } from '../i18n/en';

interface Props {
  certifications: SiteContent['certifications'];
}

const { certifications } = Astro.props;
---

<section id="certifications" class="section" style="background: var(--bg-secondary);">
  <div class="section-inner">

    <p class="section-kicker">Credentials</p>
    <h2 class="section-title">{certifications.title}</h2>

    <!-- Golden Jacket banner -->
    <div
      class="golden-jacket"
      style="
        padding: 1.5rem 2rem;
        margin-bottom: 3rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      "
    >
      <div style="font-size: 3rem; flex-shrink: 0;">🏆</div>
      <div style="flex: 1; min-width: 200px;">
        <div
          style="
            font-family: var(--font-sans);
            font-size: 1.1rem;
            font-weight: 700;
            color: #7fe0c6;
            margin-bottom: 0.25rem;
          "
        >
          AWS Golden Jacket
        </div>
        <p style="color: rgba(255,255,255,0.85); font-size: 0.9rem; margin: 0; line-height: 1.5;">
          {certifications.goldenJacketNote}
        </p>
      </div>
      <!-- 12 dots representing 12 certs -->
      <div style="display: flex; gap: 0.375rem; flex-wrap: wrap; max-width: 200px;">
        {Array.from({ length: 12 }).map((_, i) => (
          <div
            style="
              width: 10px;
              height: 10px;
              border-radius: 50%;
              background: #7fe0c6;
              opacity: 0.9;
            "
          ></div>
        ))}
      </div>
    </div>

    <!-- Categories -->
    {certifications.categories.map((category) => (
      <div style="margin-bottom: 2.5rem;">
        <h3
          style="
            font-family: var(--font-sans);
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
          "
        >
          {category.label}
        </h3>
        <div
          style="
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 1rem;
          "
        >
          {category.items.map((cert) => (
            <a
              href={cert.url}
              target="_blank"
              rel="noopener"
              class="cert-badge"
              title={cert.title}
            >
              <img
                src={cert.image}
                alt={cert.title}
                loading="lazy"
                width="80"
                height="80"
              />
              <span>{cert.title.replace('AWS Certified ', '').replace(' – ', ' – ')}</span>
            </a>
          ))}
        </div>
      </div>
    ))}

  </div>
</section>
