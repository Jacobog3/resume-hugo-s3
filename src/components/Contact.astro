---
import type { SiteContent } from '../i18n/en';

interface Props {
  contact: SiteContent['contact'];
}

const { contact } = Astro.props;
---

<section id="contact" class="section">
  <div class="section-inner">
    <div
      style="
        max-width: 600px;
        margin-inline: auto;
        text-align: center;
      "
    >
      <p class="section-kicker" style="justify-content: center;">{contact.title}</p>
      <h2 class="section-title" style="text-align: center;">{contact.title}</h2>

      <p style="color: var(--text-secondary); line-height: 1.75; margin-bottom: 2.5rem; font-size: 1.05rem;">
        {contact.content}
      </p>

      <a href={`mailto:${contact.email}`} class="btn-primary" style="margin-bottom: 2.5rem; font-size: 1rem; padding: 0.875rem 2rem;">
        {contact.btnName}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>

      <div style="display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem;">
        {contact.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            style="
              display: flex;
              align-items: center;
              gap: 0.5rem;
              font-family: var(--font-sans);
              font-size: 0.875rem;
              font-weight: 500;
              color: var(--text-secondary);
              text-decoration: none;
              transition: color 0.2s ease;
            "
            onmouseover="this.style.color='var(--primary)'"
            onmouseout="this.style.color='var(--text-secondary)'"
          >
            {link.icon === 'linkedin' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {link.icon === 'github' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            )}
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer
  style="
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
  "
>
  <p
    style="
      font-family: var(--font-sans);
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin: 0;
    "
  >
    &copy; {new Date().getFullYear()} Jacobo Gonzalez &mdash; Built with
    <a href="https://astro.build" target="_blank" rel="noopener" style="color: var(--primary); text-decoration: none;">Astro</a>
    &amp; deployed on AWS
  </p>
</footer>
